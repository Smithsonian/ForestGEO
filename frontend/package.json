{
  "name": "forestgeo-app",
  "version": "development",
  "private": true,
  "overrides": {
    "glob": "^10.3.10",
    "rimraf": "^4.0.0",
    "popper.js": "@popperjs/core"
  },
  "scripts": {
    "dev": "next dev --turbo",
    "build": "rm -rf build && next lint --fix --quiet && prettier --write . --log-level silent && next build --debug",
    "start": "node build/standalone/server.js -p 3000",
    "bs": "next build; npm run start",
    "bswin": "npm run build ; npm run start",
    "bdwin": "npm run build ; npm run dev",
    "clean": "rm -rf .next node_modules build; npm install",
    "cleanwin": "del /S /Q node_modules build; npm install",
    "lint": "next lint --fix --quiet && prettier --write . --log-level silent",
    "format": "prettier --write .",
    "test:unit": "node ./scripts/run-vitest-unit.mjs",
    "test:unit:ci": "node ./scripts/run-vitest-unit.mjs app components config lib testing tests/loading-duplicate-prevention.test.tsx tests/upload-procedure-regressions.test.ts",
    "test:unit:raw": "node --max-old-space-size=4096 ./node_modules/vitest/vitest.mjs run",
    "test:integration": "node --max-old-space-size=4096 ./node_modules/vitest/vitest.mjs run --config vitest.integration.config.mts",
    "test:integration:azure": "dotenv -e .env.testing.azure -- node --max-old-space-size=4096 ./node_modules/vitest/vitest.mjs run --config vitest.integration.config.mts",
    "test:component": "cypress run --component",
    "test:e2e": "start-server-and-test dev http://localhost:3000 \"cypress run --e2e\"",
    "test:e2e:ci": "NEXT_PUBLIC_E2E_TESTING=true start-server-and-test 'NEXT_PUBLIC_E2E_TESTING=true next dev --turbo' http://localhost:3000 \"cypress run --e2e --headless --browser chrome\"",
    "test:e2e:demo": "NEXT_PUBLIC_E2E_TESTING=true start-server-and-test 'NEXT_PUBLIC_E2E_TESTING=true next dev --turbo' http://localhost:3000 \"cypress run --e2e --headed --browser electron --spec 'cypress/e2e/demo/**/*.cy.ts' --env demoMode=true,demoDelayMs=1400\"",
    "test:e2e:demo:headless": "NEXT_PUBLIC_E2E_TESTING=true start-server-and-test 'NEXT_PUBLIC_E2E_TESTING=true next dev --turbo' http://localhost:3000 \"cypress run --e2e --headless --browser electron --spec 'cypress/e2e/demo/**/*.cy.ts' --env demoMode=true,demoDelayMs=400\"",
    "test:all": "npm run test:unit && npm run test:component && npm run test:e2e",
    "db:seed:e2e": "npx tsx tests/setup/e2e-seed.ts",
    "deploy:validations": "npx tsx scripts/deploy-validations-to-all-schemas.ts",
    "docs": "npm run dev --prefix docs",
    "docs:build": "npm run build --prefix docs",
    "docs:preview": "npm run preview --prefix docs",
    "prepare": "cd .. && husky frontend/.husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,mts,cts,json,md,mdx,css,scss,yml,yaml}": "prettier --write"
  },
  "dependencies": {
    "@azure/storage-blob": "^12.27.0",
    "@azure/storage-queue": "^12.26.0",
    "@base-ui-components/react": "^1.0.0-beta.1",
    "@codemirror/autocomplete": "^6.18.6",
    "@codemirror/lang-sql": "^6.9.0",
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@lottiefiles/dotlottie-react": "^0.14.2",
    "@microsoft/applicationinsights-react-js": "^19.3.7",
    "@microsoft/applicationinsights-web": "^3.3.9",
    "@mui/icons-material": "^7.2.0",
    "@mui/joy": "^5.0.0-beta.52",
    "@mui/lab": "^7.0.0-beta.14",
    "@mui/material": "^7.2.0",
    "@mui/system": "^7.2.0",
    "@mui/x-data-grid": "^8.7.0",
    "@mui/x-data-grid-generator": "^8.7.0",
    "@mui/x-date-pickers": "^8.7.0",
    "@next/bundle-analyzer": "^15.3.5",
    "@next/eslint-plugin-next": "^15.3.5",
    "@octokit/types": "^14.1.0",
    "@playwright/test": "^1.53.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/codemirror": "^5.60.16",
    "@types/fast-levenshtein": "^0.0.4",
    "@types/p-queue": "^3.2.1",
    "@types/papaparse": "^5.3.16",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.35.1",
    "@typescript-eslint/parser": "^8.35.1",
    "@typescript/native-preview": "^7.0.0-dev.20250804.1",
    "@uiw/react-codemirror": "^4.24.0",
    "babel-loader": "^10.0.0",
    "chalk": "^5.4.1",
    "codemirror": "^6.0.2",
    "css-loader": "^7.1.2",
    "date-fns": "^4.1.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "fast-levenshtein": "^3.0.0",
    "framer-motion": "^12.23.0",
    "idb": "^8.0.3",
    "madge": "^8.0.0",
    "moment": "^2.30.1",
    "moment-duration-format": "^2.3.2",
    "mysql2": "^3.14.1",
    "next": "^15.3.5",
    "next-auth": "^5.0.0-beta.25",
    "next-router-mock": "^1.0.2",
    "node": "^24.3.0",
    "npm-force-resolutions": "^0.0.10",
    "octokit": "^5.0.3",
    "p-queue": "^8.1.0",
    "papaparse": "^5.5.3",
    "postcss-import": "^16.1.1",
    "progress-estimator": "^0.3.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-dropzone": "^14.3.8",
    "react-markdown": "^10.1.0",
    "recharts": "^3.1.0",
    "remark-gfm": "^4.0.1",
    "sql-formatter": "^15.6.6",
    "style-loader": "^4.0.0",
    "swr": "^2.3.4",
    "tailwind-variants": "^1.0.0",
    "uuid": "^11.1.0",
    "webpack": "^5.100.2",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.8"
  },
  "browser": {
    "crypto": false,
    "stream": false
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@axe-core/react": "^4.10.2",
    "@cypress/react": "^9.0.1",
    "@cypress/webpack-dev-server": "^4.1.0",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.30.1",
    "@tailwindcss/postcss": "^4.1.11",
    "@testing-library/cypress": "^10.0.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@types/cypress": "^1.1.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.10",
    "@types/sqlstring": "^2.3.2",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "cypress": "^14.5.4",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.30.1",
    "eslint-config-next": "^15.3.5",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.1",
    "eslint-plugin-react": "^7.37.5",
    "husky": "^9.1.7",
    "jest-axe": "^10.0.0",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.4.0",
    "next-transpile-modules": "^10.0.1",
    "prettier": "^3.6.2",
    "prettier-eslint": "^16.4.2",
    "process": "^0.11.10",
    "start-server-and-test": "^2.0.12",
    "tailwindcss": "^4.1.11",
    "typescript-eslint": "^8.35.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  }
}
