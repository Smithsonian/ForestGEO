{
  "name": "forestgeo-app",
  "version": "development",
  "private": true,
  "overrides": {
    "glob": "^10.3.10",
    "rimraf": "^4.0.0",
    "popper.js": "@popperjs/core"
  },
  "scripts": {
    "dev": "next dev --turbo",
    "build": "rm -rf build && next lint --fix --quiet && prettier --write . --log-level silent && next build --debug",
    "start": "node build/standalone/server.js -p 3000",
    "bs": "next build; npm run start",
    "bswin": "npm run build ; npm run start",
    "bdwin": "npm run build ; npm run dev",
    "clean": "rm -rf .next node_modules build; npm install",
    "cleanwin": "del /S /Q node_modules build; npm install",
    "lint": "next lint --fix --quiet && prettier --write . --log-level silent",
    "format": "prettier --write .",
    "test:unit": "node --max-old-space-size=4096 ./node_modules/vitest/vitest.mjs run",
    "test:component": "cypress run --component",
    "test:e2e": "start-server-and-test dev http://localhost:3000 \"cypress run --e2e\"",
    "test:all": "npm run test:unit && npm run test:component && npm run test:e2e",
    "deploy:validations": "npx tsx scripts/deploy-validations-to-all-schemas.ts"
  },
